      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.001"/>
      <origin xyz="0 0 -0.11" rpy="0 0 0"/></inertial>
  </link>
  <joint name="right_elbow_pitch" type="revolute">
