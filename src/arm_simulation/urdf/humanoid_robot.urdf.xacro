  <!-- ═══════════════════════════════════════════════════════════════════════
       HANDS — attach to wrists via macro
       ═══════════════════════════════════════════════════════════════════════ -->
    <xacro:hand_assembly side="left"  mirror="-1"  orient_yaw="1.5708"/>
    <xacro:hand_assembly side="right" mirror="1" orient_yaw="1.5708"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LEFT LEG  (all joints fixed — standing pose)
       hip at 0.65 m → knee ~0.37 m → ankle ~0.08 m → foot bottom ~0.02 m
       ═══════════════════════════════════════════════════════════════════════ -->

  <link name="left_hip_link">
    <inertial><mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
  </link>
  <joint name="torso_to_left_hip" type="fixed">
    <parent link="torso"/><child link="left_hip_link"/>
    <origin xyz="0.09 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_thigh">
    <!-- Hip socket -->
    <visual><origin xyz="0 0 0" rpy="0 0 0">
      </origin>
      <geometry><sphere radius="0.048"/></geometry>
