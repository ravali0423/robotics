<?xml version="1.0"?>
<robot name="humanoid_simple" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- ==================== MATERIALS ==================== -->
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  
  <material name="skin">
    <color rgba="0.9 0.7 0.6 1.0"/>
  </material>
  
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  
  <material name="red_mouth">
    <color rgba="0.8 0.3 0.3 1.0"/>
  </material>

  <!-- ==================== WORLD LINK ==================== -->
  <link name="world"/>

  <!-- ==================== TORSO ==================== -->
  <link name="torso">
    <visual>
      <geometry>
        <box size="0.3 0.4 0.5"/>
      </geometry>
      <material name="dark_gray"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.4 0.5"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="world"/>
    <child link="torso"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <!-- ==================== NECK ==================== -->
  <link name="neck">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.15"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.15"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="neck_joint" type="fixed">
    <parent link="torso"/>
    <child link="neck"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
  </joint>

  <!-- ==================== HEAD ==================== -->
  <link name="head">
    <!-- Main head sphere -->
    <visual>
      <geometry>
        <sphere radius="0.18"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <!-- Left eye -->
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="black"/>
      <origin xyz="-0.08 0.08 0.12" rpy="0 0 0"/>
    </visual>
    
    <!-- Right eye -->
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0.08 0.08 0.12" rpy="0 0 0"/>
    </visual>
    
    <!-- Mouth -->
    <visual>
      <geometry>
        <box size="0.1 0.03 0.02"/>
      </geometry>
      <material name="red_mouth"/>
      <origin xyz="0 -0.08 0.05" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <sphere radius="0.18"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="neck"/>
    <child link="head"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LEFT SHOULDER ==================== -->
  <link name="left_shoulder">
    <visual>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="left_shoulder_joint" type="fixed">
    <parent link="torso"/>
    <child link="left_shoulder"/>
    <origin xyz="0.2 0.25 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LEFT UPPER ARM ==================== -->
  <link name="left_upper_arm">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.35"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 -0.175 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.35"/>
      </geometry>
      <origin xyz="0 -0.175 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
      <origin xyz="0 -0.175 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="left_elbow_joint" type="fixed">
    <parent link="left_shoulder"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LEFT FOREARM ==================== -->
  <link name="left_forearm">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 -0.15 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
      <origin xyz="0 -0.15 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.003"/>
      <origin xyz="0 -0.15 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="left_wrist_joint" type="fixed">
    <parent link="left_upper_arm"/>
    <child link="left_forearm"/>
    <origin xyz="0 -0.35 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LEFT HAND ==================== -->
  <link name="left_hand">
    <visual>
      <geometry>
        <box size="0.12 0.09 0.025"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.12 0.09 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="left_hand_joint" type="fixed">
    <parent link="left_forearm"/>
    <child link="left_hand"/>
    <origin xyz="0 -0.30 0" rpy="0 0 0"/>
  </joint>
  <!-- ==================== RIGHT SHOULDER ==================== -->
  <link name="right_shoulder">
    <visual>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="right_shoulder_joint" type="fixed">
    <parent link="torso"/>
    <child link="right_shoulder"/>
    <origin xyz="-0.2 0.25 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RIGHT UPPER ARM ==================== -->
  <link name="right_upper_arm">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.35"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 -0.175 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.35"/>
      </geometry>
      <origin xyz="0 -0.175 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
      <origin xyz="0 -0.175 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="right_elbow_joint" type="fixed">
    <parent link="right_shoulder"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RIGHT FOREARM ==================== -->
  <link name="right_forearm">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 -0.15 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
      <origin xyz="0 -0.15 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.003"/>
      <origin xyz="0 -0.15 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="right_wrist_joint" type="fixed">
    <parent link="right_upper_arm"/>
    <child link="right_forearm"/>
    <origin xyz="0 -0.35 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RIGHT HAND ==================== -->
  <link name="right_hand">
    <visual>
      <geometry>
        <box size="0.12 0.09 0.025"/>
      </geometry>
      <material name="skin"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.12 0.09 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="right_hand_joint" type="fixed">
    <parent link="right_forearm"/>
    <child link="right_hand"/>
    <origin xyz="0 -0.30 0" rpy="0 0 0"/>
  </joint>

</robot>
