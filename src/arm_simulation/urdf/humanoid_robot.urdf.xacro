    <limit lower="0" upper="2.0" effort="15" velocity="1.0"/>
  </joint>

  <link name="right_wrist">
    <visual><origin xyz="0 0 -0.015" rpy="0 0 0">
      </origin>
      <geometry><box size="0.042 0.052 0.030"/></geometry>
