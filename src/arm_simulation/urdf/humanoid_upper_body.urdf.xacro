<?xml version="1.0"?>
<robot name="humanoid_upper_body" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- ==================== BODY DIMENSIONS ==================== -->
  <!-- Head -->
  <xacro:property name="head_radius" value="0.15" />
  <xacro:property name="face_width" value="0.28" />
  <xacro:property name="face_height" value="0.32" />
  <xacro:property name="face_depth" value="0.03" />
  
  <!-- Neck -->
  <xacro:property name="neck_length" value="0.12" />
  <xacro:property name="neck_radius" value="0.04" />
  
  <!-- Shoulders -->
  <xacro:property name="shoulder_width" value="0.45" />
  <xacro:property name="shoulder_depth" value="0.15" />
  <xacro:property name="shoulder_height" value="0.08" />
  
  <!-- Torso -->
  <xacro:property name="torso_width" value="0.40" />
  <xacro:property name="torso_height" value="0.45" />
  <xacro:property name="torso_depth" value="0.20" />
  
  <!-- Arms -->
  <xacro:property name="upper_arm_length" value="0.35" />
  <xacro:property name="upper_arm_radius" value="0.05" />
  <xacro:property name="forearm_length" value="0.30" />
  <xacro:property name="forearm_radius" value="0.038" />
  <xacro:property name="wrist_length" value="0.08" />
  <xacro:property name="wrist_radius" value="0.035" />
  
  <!-- Hand palm dimensions (matching enhanced_hand_controller) -->
  <xacro:property name="hand_width"  value="0.082" />
  <xacro:property name="hand_length" value="0.110" />
  <xacro:property name="hand_height" value="0.018" />
  
  <!-- ==================== MATERIALS ==================== -->
  <material name="skin_face">
    <color rgba="0.96 0.78 0.62 1.0"/>  <!-- Light skin tone -->
  </material>
  
  <material name="skin_body">
    <color rgba="0.95 0.76 0.60 1.0"/>  <!-- Slightly darker skin -->
  </material>
  
  <material name="skin_hand">
    <color rgba="0.96 0.78 0.62 1.0"/>  <!-- Hand skin tone -->
  </material>
  
  <material name="clothing_torso">
    <color rgba="0.2 0.2 0.2 1.0"/>  <!-- Dark gray shirt -->
  </material>
  
  <material name="eyes">
    <color rgba="0.2 0.2 0.2 1.0"/>  <!-- Dark eyes -->
  </material>
  
  <material name="mouth">
    <color rgba="0.8 0.3 0.3 1.0"/>  <!-- Red mouth -->
  </material>

  <!-- ==================== WORLD LINK ==================== -->
  <link name="world">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- ==================== TORSO (MAIN BODY) ==================== -->
  <link name="torso">
    <!-- Main chest box (clothing) -->
    <visual>
      <geometry>
        <box size="${torso_width} ${torso_height} ${torso_depth}"/>
      </geometry>
      <material name="clothing_torso"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <!-- Chest highlight (skin at neckline) -->
    <visual>
      <geometry>
        <box size="${torso_width * 0.6} 0.08 ${torso_depth * 1.2}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 ${torso_height/2 - 0.04}" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <box size="${torso_width} ${torso_height} ${torso_depth}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.15"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Torso to world joint -->
  <joint name="torso_joint" type="fixed">
    <parent link="world"/>
    <child link="torso"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== NECK ==================== -->
  <link name="neck">
    <!-- Neck cylinder (skin tone) -->
    <visual>
      <geometry>
        <cylinder radius="${neck_radius}" length="${neck_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${neck_radius}" length="${neck_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Neck joint -->
  <joint name="neck_joint" type="fixed">
    <parent link="torso"/>
    <child link="neck"/>
    <origin xyz="0 0 ${torso_height/2 + neck_length/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== HEAD ==================== -->
  <link name="head">
    <!-- Head sphere -->
    <visual>
      <geometry>
        <sphere radius="${head_radius}"/>
      </geometry>
      <material name="skin_face"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <!-- Face plate (slightly forward) -->
    <visual>
      <geometry>
        <box size="${face_width} ${face_height} ${face_depth}"/>
      </geometry>
      <material name="skin_face"/>
      <origin xyz="0 0 ${head_radius - face_depth/2}" rpy="0 0 0"/>
    </visual>
    
    <!-- Left eye -->
    <visual>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="eyes"/>
      <origin xyz="${face_width/4} ${face_height/4} ${head_radius + 0.005}" rpy="0 0 0"/>
    </visual>
    
    <!-- Right eye -->
    <visual>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="eyes"/>
      <origin xyz="${-face_width/4} ${face_height/4} ${head_radius + 0.005}" rpy="0 0 0"/>
    </visual>
    
    <!-- Mouth -->
    <visual>
      <geometry>
        <box size="${face_width/3} 0.015 0.01"/>
      </geometry>
      <material name="mouth"/>
      <origin xyz="0 ${-face_height/6} ${head_radius + 0.005}" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <sphere radius="${head_radius}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.08"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Head joint -->
  <joint name="head_joint" type="fixed">
    <parent link="neck"/>
    <child link="head"/>
    <origin xyz="0 0 ${neck_length/2 + head_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SHOULDERS ==================== -->
  <link name="shoulders">
    <!-- Shoulder bar connecting both arms -->
    <visual>
      <geometry>
        <box size="${shoulder_width} ${shoulder_height} ${shoulder_depth}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <box size="${shoulder_width} ${shoulder_height} ${shoulder_depth}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Shoulders joint -->
  <joint name="shoulders_joint" type="fixed">
    <parent link="torso"/>
    <child link="shoulders"/>
    <origin xyz="0 0 ${torso_height/2 - shoulder_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LEFT ARM ==================== -->
  <!-- Left upper arm -->
  <link name="left_upper_arm">
    <visual>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Left upper arm joint -->
  <joint name="left_shoulder_joint" type="fixed">
    <parent link="shoulders"/>
    <child link="left_upper_arm"/>
    <origin xyz="${shoulder_width/2} 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Left forearm -->
  <link name="left_forearm">
    <visual>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.003"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Left elbow joint -->
  <joint name="left_elbow_joint" type="fixed">
    <parent link="left_upper_arm"/>
    <child link="left_forearm"/>
    <origin xyz="0 0 ${-upper_arm_length/2}" rpy="0 0 0"/>
  </joint>

  <!-- Left wrist -->
  <link name="left_wrist">
    <visual>
      <geometry>
        <cylinder radius="${wrist_radius}" length="${wrist_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${wrist_radius}" length="${wrist_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Left wrist joint -->
  <joint name="left_wrist_joint" type="fixed">
    <parent link="left_forearm"/>
    <child link="left_wrist"/>
    <origin xyz="0 0 ${-forearm_length/2}" rpy="0 0 0"/>
  </joint>

  <!-- Left hand base (palm) -->
  <link name="left_hand_base">
    <visual>
      <geometry>
        <box size="${hand_length} ${hand_width} ${hand_height}"/>
      </geometry>
      <material name="skin_hand"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <box size="${hand_length} ${hand_width} ${hand_height}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Left hand joint -->
  <joint name="left_hand_joint" type="fixed">
    <parent link="left_wrist"/>
    <child link="left_hand_base"/>
    <origin xyz="0 0 ${-wrist_length/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RIGHT ARM ==================== -->
  <!-- Right upper arm -->
  <link name="right_upper_arm">
    <visual>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Right upper arm joint -->
  <joint name="right_shoulder_joint" type="fixed">
    <parent link="shoulders"/>
    <child link="right_upper_arm"/>
    <origin xyz="${-shoulder_width/2} 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Right forearm -->
  <link name="right_forearm">
    <visual>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.003"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Right elbow joint -->
  <joint name="right_elbow_joint" type="fixed">
    <parent link="right_upper_arm"/>
    <child link="right_forearm"/>
    <origin xyz="0 0 ${-upper_arm_length/2}" rpy="0 0 0"/>
  </joint>

  <!-- Right wrist -->
  <link name="right_wrist">
    <visual>
      <geometry>
        <cylinder radius="${wrist_radius}" length="${wrist_length}"/>
      </geometry>
      <material name="skin_body"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${wrist_radius}" length="${wrist_length}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Right wrist joint -->
  <joint name="right_wrist_joint" type="fixed">
    <parent link="right_forearm"/>
    <child link="right_wrist"/>
    <origin xyz="0 0 ${-forearm_length/2}" rpy="0 0 0"/>
  </joint>

  <!-- Right hand base (palm) -->
  <link name="right_hand_base">
    <visual>
      <geometry>
        <box size="${hand_length} ${hand_width} ${hand_height}"/>
      </geometry>
      <material name="skin_hand"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    
    <collision>
      <geometry>
        <box size="${hand_length} ${hand_width} ${hand_height}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- Right hand joint -->
  <joint name="right_hand_joint" type="fixed">
    <parent link="right_wrist"/>
    <child link="right_hand_base"/>
    <origin xyz="0 0 ${-wrist_length/2}" rpy="0 0 0"/>
  </joint>

</robot>
