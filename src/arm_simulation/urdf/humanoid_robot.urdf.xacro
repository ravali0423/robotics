<?xml version="1.0"?>
<robot name="humanoid_robot" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- ═══════════════════════════════════════════════════════════════════════
       HUMANOID ROBOT — Full body sign-language interpreter
       Heights (world Z from ground):
         Foot bottom   ~0.05 m
         Knee          ~0.37 m
         Hip / torso   ~0.65 m
         Torso center  ~0.90 m
         Shoulder      ~1.15 m
         Head center   ~1.36 m
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- ─── Hand dimensions (copied from dual_robotic_hands.urdf.xacro) ──── -->
  <xacro:property name="hand_width"  value="0.082"/>
  <xacro:property name="hand_length" value="0.110"/>
  <xacro:property name="hand_height" value="0.018"/>

  <xacro:property name="proximal_length" value="0.036"/>
  <xacro:property name="middle_length"   value="0.026"/>
  <xacro:property name="distal_length"   value="0.020"/>

  <xacro:property name="finger_r0" value="0.0068"/>
  <xacro:property name="finger_r1" value="0.0062"/>
  <xacro:property name="finger_r2" value="0.0056"/>
  <xacro:property name="finger_r3" value="0.0048"/>

  <xacro:property name="thumb_proximal_length" value="0.032"/>
  <xacro:property name="thumb_distal_length"   value="0.024"/>
  <xacro:property name="thumb_r0" value="0.0082"/>
  <xacro:property name="thumb_r1" value="0.0075"/>
  <xacro:property name="thumb_r2" value="0.0064"/>

  <!-- ─── Material colors as xacro properties ─────────────────────────── -->
  <!-- RViz only applies color when <color> appears inside <visual><material>.
       Define each RGBA here as a property so every visual can inline it. -->
  <xacro:property name="c_body_skin"   value="0.85 0.72 0.55 1.0"/>
  <xacro:property name="c_body_dark"   value="0.30 0.20 0.15 1.0"/>
  <xacro:property name="c_hair_color"  value="0.15 0.10 0.08 1.0"/>
  <xacro:property name="c_eye_white"   value="0.95 0.95 0.95 1.0"/>
  <xacro:property name="c_eye_iris"    value="0.10 0.30 0.60 1.0"/>
  <xacro:property name="c_mouth_red"   value="0.75 0.20 0.15 1.0"/>
  <xacro:property name="c_skin_palm"   value="0.96 0.78 0.62 1.0"/>
  <xacro:property name="c_skin_finger" value="0.93 0.74 0.58 1.0"/>
  <xacro:property name="c_skin_knuckle" value="0.88 0.68 0.52 1.0"/>
  <xacro:property name="c_skin_tip"    value="0.97 0.80 0.66 1.0"/>
  <xacro:property name="c_skin_nail"   value="1.0  0.75 0.80 0.7"/>

  <!-- ─── Material macros (inline color so RViz picks it up) ───────────── -->
  <xacro:macro name="m_body_skin">   <material name="body_skin">  <color rgba="${c_body_skin}"/>   </material></xacro:macro>
  <xacro:macro name="m_body_dark">   <material name="body_dark">  <color rgba="${c_body_dark}"/>   </material></xacro:macro>
  <xacro:macro name="m_hair_color">  <material name="hair_color"> <color rgba="${c_hair_color}"/>  </material></xacro:macro>
  <xacro:macro name="m_eye_white">   <material name="eye_white">  <color rgba="${c_eye_white}"/>   </material></xacro:macro>
  <xacro:macro name="m_eye_iris">    <material name="eye_iris">   <color rgba="${c_eye_iris}"/>    </material></xacro:macro>
  <xacro:macro name="m_mouth_red">   <material name="mouth_red">  <color rgba="${c_mouth_red}"/>   </material></xacro:macro>
  <xacro:macro name="m_skin_palm">   <material name="skin_palm">    <color rgba="${c_skin_palm}"/>    </material></xacro:macro>
  <xacro:macro name="m_skin_finger"> <material name="skin_finger">  <color rgba="${c_skin_finger}"/>  </material></xacro:macro>
  <xacro:macro name="m_skin_knuckle"><material name="skin_knuckle"> <color rgba="${c_skin_knuckle}"/> </material></xacro:macro>
  <xacro:macro name="m_skin_tip">    <material name="skin_tip">     <color rgba="${c_skin_tip}"/>     </material></xacro:macro>
  <xacro:macro name="m_skin_nail">   <material name="skin_nail">    <color rgba="${c_skin_nail}"/>    </material></xacro:macro>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FINGER MACRO  (identical logic to dual_robotic_hands.urdf.xacro)
       ═══════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="finger" params="prefix parent_link x_pos y_pos z_pos rotation axis_z">

    <link name="${prefix}_proximal">
      <visual><geometry><sphere radius="${finger_r0}"/></geometry>
        <xacro:m_skin_knuckle/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <visual><geometry><cylinder radius="${finger_r1}" length="${proximal_length}"/></geometry>
        <xacro:m_skin_finger/>
        <origin xyz="${proximal_length/2} 0 0" rpy="0 1.5708 0"/></visual>
      <collision><geometry><box size="${proximal_length} ${finger_r1*2} ${finger_r1*2}"/></geometry>
        <origin xyz="${proximal_length/2} 0 0" rpy="0 0 0"/></collision>
      <inertial><mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        <origin xyz="${proximal_length/2} 0 0" rpy="0 0 0"/></inertial>
    </link>

    <link name="${prefix}_middle">
      <visual><geometry><sphere radius="${finger_r1*0.92}"/></geometry>
        <xacro:m_skin_knuckle/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <visual><geometry><cylinder radius="${finger_r2}" length="${middle_length}"/></geometry>
        <xacro:m_skin_finger/>
        <origin xyz="${middle_length/2} 0 0" rpy="0 1.5708 0"/></visual>
      <collision><geometry><box size="${middle_length} ${finger_r2*2} ${finger_r2*2}"/></geometry>
        <origin xyz="${middle_length/2} 0 0" rpy="0 0 0"/></collision>
      <inertial><mass value="0.03"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        <origin xyz="${middle_length/2} 0 0" rpy="0 0 0"/></inertial>
    </link>

    <link name="${prefix}_distal">
      <visual><geometry><sphere radius="${finger_r2*0.90}"/></geometry>
        <xacro:m_skin_knuckle/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <visual><geometry><cylinder radius="${finger_r3}" length="${distal_length}"/></geometry>
        <xacro:m_skin_finger/>
        <origin xyz="${distal_length/2} 0 0" rpy="0 1.5708 0"/></visual>
      <visual><geometry><sphere radius="${finger_r3*1.1}"/></geometry>
        <xacro:m_skin_tip/>
        <origin xyz="${distal_length} 0 0" rpy="0 0 0"/></visual>
      <collision><geometry><box size="${distal_length} ${finger_r3*2} ${finger_r3*2}"/></geometry>
        <origin xyz="${distal_length/2} 0 0" rpy="0 0 0"/></collision>
      <inertial><mass value="0.02"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        <origin xyz="${distal_length/2} 0 0" rpy="0 0 0"/></inertial>
    </link>

    <link name="${prefix}_nail">
      <visual>
        <geometry><box size="${distal_length*0.75} ${finger_r3*1.8} ${finger_r3*0.6}"/></geometry>
        <xacro:m_skin_nail/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <inertial><mass value="0.001"/>
        <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>

    <joint name="${prefix}_base_joint" type="revolute">
      <parent link="${parent_link}"/><child link="${prefix}_proximal"/>
      <origin xyz="${x_pos} ${y_pos} ${z_pos}" rpy="0 0 ${rotation}"/>
      <axis xyz="0 0 ${axis_z}"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    </joint>
    <joint name="${prefix}_proximal_joint" type="revolute">
      <parent link="${prefix}_proximal"/><child link="${prefix}_middle"/>
      <origin xyz="${proximal_length} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    </joint>
    <joint name="${prefix}_middle_joint" type="revolute">
      <parent link="${prefix}_middle"/><child link="${prefix}_distal"/>
      <origin xyz="${middle_length} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    </joint>
    <joint name="${prefix}_nail_joint" type="fixed">
      <parent link="${prefix}_distal"/><child link="${prefix}_nail"/>
      <origin xyz="${distal_length*0.5} 0 ${finger_r3*1.2}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════════════════════
       THUMB MACRO  (identical logic to dual_robotic_hands.urdf.xacro)
       ═══════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="thumb" params="prefix parent_link x_pos y_pos z_pos rotation axis_z">

    <link name="${prefix}_proximal">
      <visual><geometry><sphere radius="${thumb_r0}"/></geometry>
        <xacro:m_skin_knuckle/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <visual><geometry><cylinder radius="${thumb_r1}" length="${thumb_proximal_length}"/></geometry>
        <xacro:m_skin_finger/>
        <origin xyz="${thumb_proximal_length/2} 0 0" rpy="0 1.5708 0"/></visual>
      <collision><geometry><box size="${thumb_proximal_length} ${thumb_r1*2} ${thumb_r1*2}"/></geometry>
        <origin xyz="${thumb_proximal_length/2} 0 0" rpy="0 0 0"/></collision>
      <inertial><mass value="0.04"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        <origin xyz="${thumb_proximal_length/2} 0 0" rpy="0 0 0"/></inertial>
    </link>

    <link name="${prefix}_distal">
      <visual><geometry><sphere radius="${thumb_r1*0.90}"/></geometry>
        <xacro:m_skin_knuckle/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <visual><geometry><cylinder radius="${thumb_r2}" length="${thumb_distal_length}"/></geometry>
        <xacro:m_skin_finger/>
        <origin xyz="${thumb_distal_length/2} 0 0" rpy="0 1.5708 0"/></visual>
      <visual><geometry><sphere radius="${thumb_r2*1.15}"/></geometry>
        <xacro:m_skin_tip/>
        <origin xyz="${thumb_distal_length} 0 0" rpy="0 0 0"/></visual>
      <collision><geometry><box size="${thumb_distal_length} ${thumb_r2*2} ${thumb_r2*2}"/></geometry>
        <origin xyz="${thumb_distal_length/2} 0 0" rpy="0 0 0"/></collision>
      <inertial><mass value="0.025"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        <origin xyz="${thumb_distal_length/2} 0 0" rpy="0 0 0"/></inertial>
    </link>

    <link name="${prefix}_nail">
      <visual>
        <geometry><box size="${thumb_distal_length*0.75} ${thumb_r2*2.0} ${thumb_r2*0.6}"/></geometry>
        <xacro:m_skin_nail/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <inertial><mass value="0.001"/>
        <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>

    <joint name="${prefix}_base_joint" type="revolute">
      <parent link="${parent_link}"/><child link="${prefix}_proximal"/>
      <origin xyz="${x_pos} ${y_pos} ${z_pos}" rpy="0 0 ${rotation}"/>
      <axis xyz="0 0 ${axis_z}"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    </joint>
    <joint name="${prefix}_proximal_joint" type="revolute">
      <parent link="${prefix}_proximal"/><child link="${prefix}_distal"/>
      <origin xyz="${thumb_proximal_length} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    </joint>
    <joint name="${prefix}_nail_joint" type="fixed">
      <parent link="${prefix}_distal"/><child link="${prefix}_nail"/>
      <origin xyz="${thumb_distal_length*0.5} 0 ${thumb_r2*1.2}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HAND ASSEMBLY MACRO
       Key difference from dual_robotic_hands: parent is ${side}_wrist, not world.
       mirror= 1 → left  (thumb at -Y, abduction +Z)
       mirror=-1 → right (thumb at +Y, abduction -Z)
       ═══════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="hand_assembly" params="side mirror orient_yaw:=0">

    <link name="${side}_hand_base">
      <visual><geometry><box size="${hand_length} ${hand_width} ${hand_height}"/></geometry>
        <xacro:m_skin_palm/><origin xyz="0 0 0" rpy="0 0 0"/></visual>
      <collision><geometry><box size="${hand_length} ${hand_width} ${hand_height}"/></geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/></collision>
      <inertial><mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>

    <!-- Attach hand below wrist. rpy="0 1.5708 0" maps hand +X → wrist -Z
         so fingers point downward (away from arm) in neutral pose. -->
    <joint name="${side}_hand_orient" type="fixed">
      <parent link="${side}_wrist"/>
      <child link="${side}_hand_base"/>
      <origin xyz="0 0 -0.04" rpy="0 0 ${orient_yaw}"/>
    </joint>

    <xacro:thumb  prefix="${side}_thumb"  parent_link="${side}_hand_base"
                  x_pos="0.00"  y_pos="${mirror * -0.032}" z_pos="0.0"
                  rotation="${mirror * -0.7}" axis_z="${mirror}"/>
    <xacro:finger prefix="${side}_index"  parent_link="${side}_hand_base"
                  x_pos="0.055" y_pos="${mirror * -0.028}" z_pos="0.0"
                  rotation="0" axis_z="${mirror}"/>
    <xacro:finger prefix="${side}_middle" parent_link="${side}_hand_base"
                  x_pos="0.058" y_pos="${mirror * -0.009}" z_pos="0.0"
                  rotation="0" axis_z="${mirror}"/>
    <xacro:finger prefix="${side}_ring"   parent_link="${side}_hand_base"
                  x_pos="0.055" y_pos="${mirror *  0.010}" z_pos="0.0"
                  rotation="0" axis_z="${mirror}"/>
    <xacro:finger prefix="${side}_pinky"  parent_link="${side}_hand_base"
                  x_pos="0.048" y_pos="${mirror *  0.028}" z_pos="0.0"
                  rotation="0" axis_z="${mirror}"/>
  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BODY — ROOT LINKS
       ═══════════════════════════════════════════════════════════════════════ -->

  <link name="world">
    <inertial><mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
  </link>

  <link name="base_link">
    <inertial><mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/><child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
  </joint>

  <!-- ─── TORSO ────────────────────────────────────────────────────────── -->
  <!-- Torso origin at 0.65 m above ground; visual cylinder spans 0.65–1.09 m -->
  <link name="torso">
    <!-- Main trunk -->
    <visual><origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.44"/></geometry>
      <xacro:m_body_dark/></visual>
    <!-- Collar bone / chest highlight -->
    <visual><origin xyz="0 0 0.44" rpy="0 0 0"/>
      <geometry><box size="0.28 0.06 0.02"/></geometry>
      <xacro:m_body_skin/></visual>
    <collision><origin xyz="0 0 0.22" rpy="0 0 0"/>
      <geometry><cylinder radius="0.15" length="0.44"/></geometry></collision>
    <inertial><mass value="20.0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.3"/>
      <origin xyz="0 0 0.22" rpy="0 0 0"/></inertial>
  </link>

  <joint name="base_to_torso" type="fixed">
    <parent link="base_link"/><child link="torso"/>
    <origin xyz="0 0 0.65" rpy="0 0 0"/>
  </joint>

  <!-- ─── HEAD & NECK ──────────────────────────────────────────────────── -->
  <link name="neck_base">
    <inertial><mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
  </link>
  <joint name="torso_to_neck" type="fixed">
    <parent link="torso"/><child link="neck_base"/>
    <origin xyz="0 0 0.44" rpy="0 0 0"/>
  </joint>

  <link name="neck">
    <visual><origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.10"/></geometry>
      <xacro:m_body_skin/></visual>
    <collision><origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.10"/></geometry></collision>
    <inertial><mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/></inertial>
  </link>
  <joint name="neck_pitch" type="revolute">
    <parent link="neck_base"/><child link="neck"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3" upper="0.5" effort="5" velocity="1.0"/>
  </joint>

  <link name="head">
    <!-- Skull -->
    <visual><origin xyz="0 0 0.11" rpy="0 0 0"/>
      <geometry><sphere radius="0.11"/></geometry>
      <xacro:m_body_skin/></visual>
    <!-- Hair cap (slightly larger sphere, darker) -->
    <visual><origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry><sphere radius="0.095"/></geometry>
      <xacro:m_hair_color/></visual>
    <!-- Left eye white (robot faces +Y toward viewer) -->
    <visual><origin xyz="0.038 0.09 0.14" rpy="0 0 0"/>
      <geometry><sphere radius="0.018"/></geometry>
      <xacro:m_eye_white/></visual>
    <!-- Right eye white -->
    <visual><origin xyz="-0.038 0.09 0.14" rpy="0 0 0"/>
      <geometry><sphere radius="0.018"/></geometry>
      <xacro:m_eye_white/></visual>
    <!-- Left iris -->
    <visual><origin xyz="0.038 0.108 0.14" rpy="-1.5708 0 0"/>
      <geometry><cylinder radius="0.010" length="0.004"/></geometry>
      <xacro:m_eye_iris/></visual>
    <!-- Right iris -->
    <visual><origin xyz="-0.038 0.108 0.14" rpy="-1.5708 0 0"/>
      <geometry><cylinder radius="0.010" length="0.004"/></geometry>
      <xacro:m_eye_iris/></visual>
    <!-- Mouth -->
    <visual><origin xyz="0 0.107 0.085" rpy="0 0 0"/>
      <geometry><box size="0.052 0.004 0.010"/></geometry>
      <xacro:m_mouth_red/></visual>
    <collision><origin xyz="0 0 0.11" rpy="0 0 0"/>
      <geometry><sphere radius="0.11"/></geometry></collision>
    <inertial><mass value="3.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.025"/>
      <origin xyz="0 0 0.11" rpy="0 0 0"/></inertial>
  </link>
  <joint name="neck_yaw" type="revolute">
    <parent link="neck"/><child link="head"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="5" velocity="1.0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LEFT ARM
       Joint chain: torso → left_shoulder_link (fixed)
                    → left_upper_arm  [left_shoulder_pitch, y-axis]
                    → left_forearm_base [left_shoulder_roll, x-axis]
                    → left_forearm  [left_elbow_pitch, y-axis]
                    → left_wrist    [left_wrist_pitch, y-axis]
                    → left_hand_base (via hand_assembly macro, fixed)
       ═══════════════════════════════════════════════════════════════════════ -->

  <link name="left_shoulder_link">
    <inertial><mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
  </link>
  <joint name="torso_to_left_shoulder" type="fixed">
    <parent link="torso"/><child link="left_shoulder_link"/>
    <origin xyz="0.22 0 0.44" rpy="0 0 0"/>
  </joint>

  <link name="left_upper_arm">
    <!-- Shoulder ball -->
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.045"/></geometry>
      <xacro:m_body_skin/></visual>
    <!-- Arm cylinder — extends -Z from shoulder -->
    <visual><origin xyz="0 0 -0.13" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.26"/></geometry>
      <xacro:m_body_skin/></visual>
    <collision><origin xyz="0 0 -0.13" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.26"/></geometry></collision>
    <inertial><mass value="2.0"/>
      <inertia ixx="0.012" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.002"/>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/></inertial>
  </link>
  <joint name="left_shoulder_pitch" type="revolute">
    <parent link="left_shoulder_link"/><child link="left_upper_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="1.0"/>
  </joint>

  <!-- Intermediate link for shoulder roll (placed at elbow point) -->
  <link name="left_forearm_base">
    <inertial><mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/></inertial>
  </link>
  <joint name="left_shoulder_roll" type="revolute">
    <parent link="left_upper_arm"/><child link="left_forearm_base"/>
    <origin xyz="0 0 -0.26" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="1.57" effort="20" velocity="1.0"/>
  </joint>

  <link name="left_forearm">
    <!-- Elbow bump -->
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.032"/></geometry>
      <xacro:m_body_skin/></visual>
    <!-- Forearm cylinder -->
    <visual><origin xyz="0 0 -0.11" rpy="0 0 0">
      </origin>
      <geometry><cylinder radius="0.032" length="0.22"/></geometry>
      <xacro:m_body_skin/></visual>
    <collision><origin xyz="0 0 -0.11" rpy="0 0 0">
      </origin>
      <geometry><cylinder radius="0.032" length="0.22"/></geometry></collision>
    <inertial><mass value="1.5"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.001"/>
      <origin xyz="0 0 -0.11" rpy="0 0 0"/></inertial>
  </link>
  <joint name="left_elbow_pitch" type="revolute">
    <parent link="left_forearm_base"/><child link="left_forearm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.0" effort="15" velocity="1.0"/>
  </joint>

  <link name="left_wrist">
    <visual><origin xyz="0 0 -0.015" rpy="0 0 0"/>
      <geometry><box size="0.042 0.052 0.030"/></geometry>
      <xacro:m_body_skin/></visual>
    <collision><origin xyz="0 0 -0.015" rpy="0 0 0">
      </origin>
      <geometry><box size="0.042 0.052 0.030"/></geometry></collision>
    <inertial><mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      <origin xyz="0 0 -0.015" rpy="0 0 0"/></inertial>
  </link>
  <joint name="left_wrist_pitch" type="revolute">
    <parent link="left_forearm"/><child link="left_wrist"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RIGHT ARM  (mirror of left — x offsets negated)
       ═══════════════════════════════════════════════════════════════════════ -->

  <link name="right_shoulder_link">
