      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.005"/>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/></inertial>
  </link>
  <joint name="left_hip_pitch" type="fixed">
    <parent link="left_hip_link"/><child link="left_thigh"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_shin">
    <!-- Knee bump -->
    <visual><origin xyz="0 0 0" rpy="0 0 0">
